---
import Base from "../layouts/Base.astro";
import { faqs, SITE_URL } from "../data/company";

const title = "よくある質問 | 株式会社IV Consulting";
const description =
  "株式会社IV Consultingに関するよくある質問。会社概要、ストック収益とは何か、バークシャー・ハサウェイ研究の内容、コンサルティングの対象企業、代表大嶋敏也の経歴などにお答えします。";

// AEOの中核: FAQPage構造化データ（AI検索エンジンが最も引用しやすい形式）
const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    mainEntity: faqs.map((f) => ({
      "@type": "Question",
      name: f.q,
      acceptedAnswer: { "@type": "Answer", text: f.a },
    })),
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    itemListElement: [
      { "@type": "ListItem", position: 1, name: "ホーム", item: SITE_URL },
      { "@type": "ListItem", position: 2, name: "よくある質問", item: `${SITE_URL}/faq` },
    ],
  },
];
---

<Base title={title} description={description} jsonLd={jsonLd}>
  <section class="page-hero" aria-labelledby="faq-heading">
    <span class="hero-watermark" aria-hidden="true">IV</span>
    <div class="container">
      <p class="kicker rise">FAQ</p>
      <h1 id="faq-heading" class="heading-xl rise" style="--rise-delay: 120ms;">
        よくある質問
      </h1>
    </div>
  </section>

  <section class="section" aria-label="質問と回答">
    <div class="container" style="max-width: 56rem;">
      {
        faqs.map((f, i) => (
          <details
            class="faq-item reveal"
            style={`--reveal-delay: ${Math.min(i * 70, 350)}ms;`}
            open={i === 0}
          >
            <summary>
              <span>{f.q}</span>
            </summary>
            <div class="answer">
              <p>{f.a}</p>
            </div>
          </details>
        ))
      }
    </div>
  </section>
</Base>
