---
import { getCollection } from "astro:content";
import Base from "../../layouts/Base.astro";
import { SITE_URL } from "../../data/company";

const posts = (await getCollection("research")).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

const title = "リサーチノート | 株式会社IV Consulting";
const description =
  "バークシャー・ハサウェイの株主への手紙、アニュアルレポート、オーナーズ・マニュアルなど一次資料に基づくIV Consultingの研究成果。ストック収益、フロート、資本配分の原則を日本企業の実務に翻訳します。";

const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "CollectionPage",
    name: title,
    url: `${SITE_URL}/research`,
    hasPart: posts.map((p) => ({
      "@type": "Article",
      headline: p.data.title,
      url: `${SITE_URL}/research/${p.id}`,
      datePublished: p.data.pubDate.toISOString().slice(0, 10),
    })),
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    itemListElement: [
      { "@type": "ListItem", position: 1, name: "ホーム", item: SITE_URL },
      { "@type": "ListItem", position: 2, name: "リサーチ", item: `${SITE_URL}/research` },
    ],
  },
];
---

<Base title={title} description={description} jsonLd={jsonLd}>
  <section class="page-hero" aria-labelledby="research-heading">
    <span class="hero-watermark" aria-hidden="true">IV</span>
    <div class="container">
      <p class="kicker rise">Research Notes</p>
      <h1
        id="research-heading"
        class="heading-xl rise"
        style="--rise-delay: 120ms;"
      >
        リサーチノート
      </h1>
      <p class="prose lead rise" style="margin-top: 2rem; --rise-delay: 260ms;">
        私たちの提供価値は研究の深さです。バークシャー・ハサウェイの一次資料
        （株主への手紙・アニュアルレポート・オーナーズ・マニュアル）に基づく
        研究成果を、そのまま公開しています。
      </p>
    </div>
  </section>

  <section class="section" aria-label="記事一覧">
    <div class="container">
      <div class="row-list">
        {
          posts.map((post, i) => (
            <article class="row-item reveal">
              <span class="no" aria-hidden="true">
                {String(i + 1).padStart(2, "0")}
              </span>
              <div>
                <h2 class="heading-md">
                  <a href={`/research/${post.id}`} style="text-decoration: none;">
                    {post.data.title}
                  </a>
                </h2>
                <p class="prose" style="margin-top: 0.75rem; color: var(--ink-soft);">
                  {post.data.description}
                </p>
                <p
                  style="margin-top: 1rem; font-family: var(--font-sans); font-size: var(--text-label); letter-spacing: 0.2em; color: var(--ink-soft);"
                >
                  <time datetime={post.data.pubDate.toISOString().slice(0, 10)}>
                    {post.data.pubDate.toLocaleDateString("ja-JP", {
                      year: "numeric",
                      month: "long",
                      day: "numeric",
                    })}
                  </time>
                </p>
              </div>
            </article>
          ))
        }
      </div>
    </div>
  </section>
</Base>
