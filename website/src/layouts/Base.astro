---
import { company, ceo, SITE_URL } from "../data/company";
import "../styles/global.css";

interface Props {
  title: string;
  description: string;
  /** ページ固有の追加JSON-LD（FAQPage, Article等） */
  jsonLd?: Record<string, unknown>[];
  ogType?: "website" | "article";
}

const { title, description, jsonLd = [], ogType = "website" } = Astro.props;

const base = import.meta.env.BASE_URL.replace(/\/$/, "");
const canonical = new URL(Astro.url.pathname, Astro.site ?? SITE_URL).href;
const currentPath = Astro.url.pathname.replace(/\/$/, "") || "/";
const basePath = (path: string) => (path === "/" ? base || "/" : `${base}${path}`);

// 全ページ共通の構造化データ: Organization + WebSite + Person(代表)
const baseJsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "Organization",
    "@id": `${SITE_URL}/#organization`,
    name: company.nameJa,
    alternateName: company.nameEn,
    url: SITE_URL,
    foundingDate: "2025-07",
    description: company.description,
    address: {
      "@type": "PostalAddress",
      addressRegion: "東京都",
      addressCountry: "JP",
    },
    founder: { "@id": `${SITE_URL}/#ceo` },
    knowsAbout: [
      "バークシャー・ハサウェイ研究",
      "ウォーレン・バフェットの投資哲学",
      "ストック収益モデル",
      "資本配分（キャピタル・アロケーション）",
      "経営管理",
      "グループ経営",
    ],
  },
  {
    "@context": "https://schema.org",
    "@type": "Person",
    "@id": `${SITE_URL}/#ceo`,
    name: ceo.nameJa,
    alternateName: ceo.nameEn,
    jobTitle: ceo.title,
    worksFor: { "@id": `${SITE_URL}/#organization` },
    sameAs: [ceo.linkedin],
    description: ceo.summary,
  },
  {
    "@context": "https://schema.org",
    "@type": "WebSite",
    "@id": `${SITE_URL}/#website`,
    name: company.nameJa,
    url: SITE_URL,
    inLanguage: "ja",
    publisher: { "@id": `${SITE_URL}/#organization` },
  },
];

const allJsonLd = [...baseJsonLd, ...jsonLd];

const nav = [
  { href: basePath("/"), label: "ホーム" },
  { href: basePath("/about"), label: "会社概要" },
  { href: basePath("/services"), label: "サービス" },
  { href: basePath("/research"), label: "リサーチ" },
  { href: basePath("/faq"), label: "よくある質問" },
];

const isCurrent = (href: string) => {
  const norm = currentPath.replace(base, "") || "/";
  const hrefNorm = href.replace(base, "") || "/";
  return hrefNorm === "/" ? norm === "/" : norm.startsWith(hrefNorm);
};
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <script is:inline>
      // JS有効時のみ .reveal を初期非表示にするためのフラグ（FOUC/no-JS対策）
      document.documentElement.classList.add("js");
    </script>
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <link rel="icon" type="image/svg+xml" href={`${base}/favicon.svg`} />
    <link rel="sitemap" href={`${base}/sitemap-index.xml`} />

    <meta property="og:type" content={ogType} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:site_name" content={company.nameJa} />
    <meta property="og:locale" content="ja_JP" />
    <meta name="twitter:card" content="summary" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Shippori+Mincho:wght@500;600;700&display=swap"
    />

    {
      allJsonLd.map((schema) => (
        <script
          type="application/ld+json"
          set:html={JSON.stringify(schema)}
        />
      ))
    }
  </head>
  <body>
    <header class="site-header">
      <div class="container masthead">
        <a href={basePath("/")} class="masthead-brand"
          ><span class="mark">IV</span> Consulting</a
        >
        <nav class="masthead-nav" aria-label="メインナビゲーション">
          {
            nav.map((item) => (
              <a
                href={item.href}
                aria-current={isCurrent(item.href) ? "page" : undefined}
              >
                {item.label}
              </a>
            ))
          }
        </nav>
      </div>
    </header>

    <main>
      <slot />
    </main>

    <footer class="site-footer">
      <div class="container cols">
        <div>
          <p style="font-weight:700; color:var(--ink); letter-spacing:0.1em;">
            {company.nameJa}
          </p>
          <p>{company.location} ／ 設立 {company.founded}</p>
          <p style="margin-top:0.5rem;">{company.tagline}</p>
        </div>
        <div>
          <p>
            代表取締役CEO {ceo.nameJa}（<a
              href={ceo.linkedin}
              rel="noopener"
              target="_blank">LinkedIn</a
            >）
          </p>
          <p style="margin-top:0.5rem;">
            © 2025–{new Date().getFullYear()} {company.nameEn}
          </p>
        </div>
      </div>
    </footer>

    <script is:inline>
      // スクロールリビール: 交差した要素に .is-visible を一度だけ付与する
      (function () {
        var els = document.querySelectorAll(".reveal");
        var reduced = window.matchMedia(
          "(prefers-reduced-motion: reduce)",
        ).matches;

        if (reduced || !("IntersectionObserver" in window)) {
          els.forEach(function (el) {
            el.classList.add("is-visible");
          });
          return;
        }

        var io = new IntersectionObserver(
          function (entries) {
            entries.forEach(function (entry) {
              if (entry.isIntersecting) {
                entry.target.classList.add("is-visible");
                io.unobserve(entry.target);
              }
            });
          },
          { threshold: 0.12, rootMargin: "0px 0px -8% 0px" },
        );

        els.forEach(function (el) {
          io.observe(el);
        });
      })();
    </script>
  </body>
</html>
